# Copy this file to .env.local for local dev (gitignored).
# Supabase NEXT_PUBLIC_* values for production builds are in .env.production (tracked) for AWS/GitHub.
# Do not commit .env.local — it usually contains OPENAI_API_KEY and other secrets.

# --- Local only: browse without login on http://localhost:3003 (or 127.0.0.1). Never set on production. ---
# NEXT_PUBLIC_PARABLE_DEV_GUEST=1
# Optional production preview hosts (comma-separated) when DEV_GUEST=1:
# NEXT_PUBLIC_PARABLE_GUEST_HOSTS=www.your-domain.com,your-domain.com

# --- PARABLE Study AI only: set this so nav and home show Study AI (Sanctuary, Table, Lab) ---
# NEXT_PUBLIC_APP_VARIANT=parable-study-ai

# --- Testify (/testify) demo feed: fake community posts for UI feel. Default off (same as prod); set true to preview. ---
# NEXT_PUBLIC_TESTIFY_DEMO_FEED=true

# --- My Sanctuary home (/my-sanctuary): demo | live | hybrid (default hybrid). ---
# NEXT_PUBLIC_SANCTUARY_HOME_MODE=hybrid
# Optional SQL: supabase/schema-sanctuary-home.sql, schema-sanctuary-event-registrations.sql
# Spec: docs/SANCTUARY_HOME_FEED_SPEC.md

# --- Profile Instagram layout: legacy (default) | blueprint (Tailwind `InstagramProfileView` bridge) ---
# Applies to `/profile` when set; `/profile/blueprint` always uses the blueprint view.
# NEXT_PUBLIC_PROFILE_IG_VIEW=blueprint

# --- Supabase (required for auth & The Table groups) ---
# Use your Supabase Project URL from Dashboard → Settings → API (https://YOUR_REF.supabase.co).
# Do NOT use your app website URL here — parableaccountant.com is the frontend, not the Supabase API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Dev: default is relay on. If sign-in throws "Failed to fetch", set 0 so the browser calls *.supabase.co directly.
# NEXT_PUBLIC_SUPABASE_BROWSER_RELAY=0

# --- OpenAI (required for AI Scholar: Theory Solver, De-Coder, Steel Man) ---
OPENAI_API_KEY=sk-your-openai-api-key-here


# --- LiveKit (live studio: /live-studio, POST /api/livekit/token) ---
# Server-only: key + secret. URL is safe to expose; use same wss host for both.
# LIVEKIT_API_KEY=API2q6bdXcKnBJ6
# LIVEKIT_API_SECRET=o3HtiVoKwSrpqkQfaSnhnhAeEm8LykGVHAyZYWNdlqW
# LIVEKIT_URL=wss://parable-gkh2cjih.livekit.cloud
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# NEXT_PUBLIC_TESTIFY_DEMO_FEED=true

# --- Gamers Hub (/gaming): Minecraft IP, Roblox place, voice lobby link, Wordle iframe URL ---
# NEXT_PUBLIC_MINECRAFT_SERVER_IP=play.your-sanctuary.net
# NEXT_PUBLIC_ROBLOX_PLACE_ID=1234567890
# NEXT_PUBLIC_GAMING_VOICE_LOBBY_URL=https://discord.gg/your-invite
# NEXT_PUBLIC_WORDLE_EMBED_URL=https://example.com/embeddable-wordle
